  "grammar": [
    {
      "title": {
        "de": "Definiter Artikel: der, das, die",
        "es": "Articulo definido: der, das, die",
        "en": "Definite article: der, das, die",
        "ar": "أداة التعريف: der, das, die",
        "uk": "Означений артикль: der, das, die",
        "tr": "Belirli artikel: der, das, die"
      },
      "explanation": {
        "de": "Jedes Nomen hat einen Artikel. Wir mussen ihn immer mitlernen!",
        "es": "Cada sustantivo tiene un articulo. Tenemos que aprenderlo siempre con la palabra!",
        "en": "Every noun has an article. We must always learn it together with the word!",
        "ar": "لكل اسم أداة تعريف. يجب تعلمها مع الكلمة دائما!",
        "uk": "Кожен iменник має артикль. Завжди вчимо разом зi словом!",
        "tr": "Her ismin bir artikeli vardir. Her zaman kelimeyle birlikte ogrenmeliyiz!"
      },
      "table": {
        "headers": ["Genus", "definit", "Beispiel"],
        "rows": [
          ["maskulin (m)", "der", "der Tisch"],
          ["neutral (n)", "das", "das Bett"],
          ["feminin (f)", "die", "die Lampe"],
          ["Plural (pl)", "die", "die Stuhle"]
        ]
      }
    },
    {
      "title": {
        "de": "Negation: nicht",
        "es": "Negacion: nicht",
        "en": "Negation: nicht",
        "ar": "النفي: nicht",
        "uk": "Заперечення: nicht",
        "tr": "Olumsuzluk: nicht"
      },
      "explanation": {
        "de": "nicht negiert das Verb oder das Adjektiv. kein/keine negiert das Nomen.",
        "es": "nicht niega el verbo o el adjetivo. kein/keine niega el sustantivo.",
        "en": "nicht negates the verb or adjective. kein/keine negates the noun.",
        "ar": "nicht ينفي الفعل أو الصفة. kein/keine ينفي الاسم.",
        "uk": "nicht заперечує дiєслово або прикметник. kein/keine заперечує iменник.",
        "tr": "nicht fiili veya sifati olumsuz yapar. kein/keine ismi olumsuz yapar."
      },
      "examples": [
        "Das Zimmer ist nicht gross.",
        "Ich wohne nicht in Berlin.",
        "Wir haben kein Wohnzimmer."
      ]
    },
    {
      "title": {
        "de": "Komposita - zusammengesetzte Nomen",
        "es": "Palabras compuestas",
        "en": "Compound nouns",
        "ar": "الأسماء المركبة",
        "uk": "Складнi iменники",
        "tr": "Birlesik isimler"
      },
      "explanation": {
        "de": "Im Deutschen verbinden wir oft zwei Nomen. Der Artikel kommt vom letzten Wort: der Schrank + der Kuhl... -> der Kuhlschrank.",
        "es": "En aleman a menudo unimos dos sustantivos. El articulo viene de la ULTIMA palabra: der Schrank + Kuhl- -> der Kuhlschrank (frigorifico).",
        "en": "In German we often combine two nouns. The article comes from the LAST word: der Schrank -> der Kuhlschrank.",
        "ar": "في الألمانية نجمع كثيرا اسمين معا. أداة التعريف تأتي من الكلمة الأخيرة.",
        "uk": "У нiмецькiй часто з'єднуємо два iменники. Артикль вiд останнього слова.",
        "tr": "Almancada genellikle iki ismi birlestiririz. Artikel SON kelimeden gelir."
      },
      "examples": [
        "das Schlaf + das Zimmer = das Schlafzimmer",
        "die Wasch + die Maschine = die Waschmaschine",
        "der Kuhl + der Schrank = der Kuhlschrank"
      ]
    }
  ],

