  "grammar": [
    {
      "title": {
        "de": "Akkusativ - der direkte Objekt",
        "es": "Acusativo - el objeto directo",
        "en": "Accusative - the direct object",
        "ar": "حالة المفعول به",
        "uk": "Знахiдний вiдмiнок - прямий додаток",
        "tr": "Ismin -i hali - dogrudan nesne"
      },
      "explanation": {
        "de": "Beim Akkusativ andert sich nur der maskuline Artikel: der wird den, ein wird einen, kein wird keinen. Das/die andern sich NICHT!",
        "es": "En acusativo solo cambia el articulo masculino: der -> den, ein -> einen, kein -> keinen. Das y die NO cambian!",
        "en": "In accusative ONLY the masculine article changes: der -> den, ein -> einen, kein -> keinen. Das and die do NOT change!",
        "ar": "في حالة المفعول، فقط الأداة المذكرة تتغير: der -> den، ein -> einen، kein -> keinen.",
        "uk": "У знахiдному вiдмiнку змiнюється тiльки чоловiчий артикль: der -> den, ein -> einen.",
        "tr": "Ismin -i halinde sadece eril artikel degisir: der -> den, ein -> einen."
      },
      "table": {
        "headers": ["Genus", "Nominativ", "Akkusativ"],
        "rows": [
          ["maskulin", "der/ein/kein Salat", "den/einen/keinen Salat"],
          ["neutral", "das/ein/kein Brot", "das/ein/kein Brot"],
          ["feminin", "die/eine/keine Pizza", "die/eine/keine Pizza"],
          ["Plural", "die/-/keine Tomaten", "die/-/keine Tomaten"]
        ]
      },
      "examples": [
        "Ich nehme den Salat. (m)",
        "Ich mochte einen Tee. (m)",
        "Ich trinke keinen Saft. (m)",
        "Ich esse das Brot. (n - sin cambio)"
      ]
    },
    {
      "title": {
        "de": "ja, nein, doch",
        "es": "ja, nein, doch",
        "en": "ja, nein, doch",
        "ar": "ja, nein, doch",
        "uk": "ja, nein, doch",
        "tr": "ja, nein, doch"
      },
      "explanation": {
        "de": "ja = bestatigt eine positive Frage. nein = verneint. doch = bestatigt nach einer NEGATIVEN Frage. Bei negativer Frage immer doch verwenden!",
        "es": "ja = confirma una pregunta positiva. nein = niega. doch = confirma despues de una pregunta NEGATIVA. Tras pregunta negativa siempre doch!",
        "en": "ja = confirms a positive question. nein = negates. doch = confirms after a NEGATIVE question. After negative question always use doch!",
        "ar": "ja = نعم لسؤال إيجابي. nein = لا. doch = نعم بعد سؤال سلبي.",
        "uk": "ja = так на позитивне питання. nein = нi. doch = так на НЕГАТИВНЕ питання.",
        "tr": "ja = olumlu soruya evet. nein = hayir. doch = OLUMSUZ soruya evet."
      },
      "examples": [
        "Hast du Hunger? - Ja, ich habe Hunger.",
        "Hast du Hunger? - Nein, ich habe keinen Hunger.",
        "Hast du KEINEN Hunger? - Doch, ich habe Hunger! (correccion)",
        "Hast du KEINEN Hunger? - Nein, ich habe keinen. (confirmacion)"
      ]
    },
    {
      "title": {
        "de": "Verben mit Vokalwechsel",
        "es": "Verbos con cambio de vocal",
        "en": "Verbs with vowel change",
        "ar": "الأفعال مع تغير الحرف",
        "uk": "Дiєслова з чергуванням голосних",
        "tr": "Sesli degisimi olan fiiller"
      },
      "explanation": {
        "de": "Einige wichtige Verben andern den Vokal in der du- und er/sie/es-Form: e -> i/ie, a -> a.",
        "es": "Algunos verbos importantes cambian la vocal en las formas du y er/sie/es: e -> i/ie, a -> a.",
        "en": "Some important verbs change vowel in du and er/sie/es forms: e -> i/ie, a -> a.",
        "ar": "بعض الأفعال تغير الحرف في صيغ du و er/sie/es.",
        "uk": "Деякi дiєслова змiнюють голосну у формах du i er/sie/es.",
        "tr": "Bazi fiiller du ve er/sie/es formlarinda sesli degistirir."
      },
      "table": {
        "headers": ["Verb", "ich", "du", "er/sie"],
        "rows": [
