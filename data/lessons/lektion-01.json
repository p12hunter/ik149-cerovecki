  "grammar": [
    {
      "title": {
        "de": "Personalpronomen",
        "es": "Pronombres personales",
        "en": "Personal pronouns",
        "ar": "الضمائر الشخصية",
        "uk": "Особовi займенники",
        "tr": "Sahis zamirleri",
        "bs": "Licne zamjenice"
      },
      "explanation": {
        "de": "Die Personalpronomen im Singular sind: ich, du, er/sie/es. Im Plural: wir, ihr, sie. Sie (mit grossem S) ist die formelle Anrede.",
        "es": "Los pronombres personales en singular son: ich (yo), du (tu), er/sie/es (el/ella/ello). En plural: wir (nosotros), ihr (vosotros), sie (ellos). Sie (con S mayuscula) es la forma formal de tratamiento.",
        "en": "Singular personal pronouns: ich (I), du (you informal), er/sie/es (he/she/it). Plural: wir (we), ihr (you all), sie (they). Sie (capital S) is the formal address.",
        "ar": "ضمائر المفرد: ich (أنا)، du (أنت)، er/sie/es (هو/هي/هو محايد). الجمع: wir (نحن)، ihr (أنتم)، sie (هم). Sie بحرف كبير صيغة احترام.",
        "uk": "Займенники однини: ich (я), du (ти), er/sie/es (вiн/вона/воно). Множина: wir (ми), ihr (ви), sie (вони). Sie з великої - ввiчлива форма.",
        "tr": "Tekil sahis zamirleri: ich (ben), du (sen), er/sie/es (o erkek/kadin/notr). Cogul: wir (biz), ihr (siz), sie (onlar). Sie (buyuk S) resmi hitap.",
        "bs": "Licne zamjenice u jednini su: ich (ja), du (ti), er/sie/es (on/ona/ono). U mnozini: wir (mi), ihr (vi), sie (oni). Sie sa velikim S je formalno obracanje."
      },
      "table": {
        "headers": [
