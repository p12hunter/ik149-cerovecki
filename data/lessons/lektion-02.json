    {
      "title": {
        "de": "Praposition in + Stadt/Land",
        "es": "Preposicion in + ciudad/pais",
        "en": "Preposition in + city/country",
        "ar": "حرف الجر in + المدينة / البلد",
        "uk": "Прийменник in + мiсто/країна",
        "tr": "Edat in + sehir/ulke",
        "bs": "Prijedlog in + grad/drzava"
      },
      "explanation": {
        "de": "Mit in sagen wir, wo wir wohnen oder leben. Bei Stadten ohne Artikel: in Madrid, in Berlin. Bei Landern mit Artikel: in der Turkei, in den USA.",
        "es": "Con in decimos donde vivimos. Con ciudades sin articulo: in Madrid, in Berlin. Con paises que llevan articulo: in der Turkei, in den USA.",
        "en": "With in we say where we live. Cities without article: in Madrid, in Berlin. Countries with article: in der Turkei, in den USA.",
        "ar": "مع in نقول أين نعيش. مع المدن بدون أداة: in Madrid. مع البلدان بأداة: in der Turkei.",
        "uk": "З in говоримо де живемо. Мiста без артикля. Країни з артиклем: in der Turkei.",
        "tr": "in ile nerede yasadigimizi soyleriz. Sehir artikelsiz. Artikelli ulke: in der Turkei.",
        "bs": "Sa in kazemo gdje zivimo. Gradovi bez clana. Drzave sa clanom: in der Turkei."
      },
      "examples": [
        "Ich wohne in Munchen.",
        "Sie lebt in der Turkei.",
        "Wir wohnen in den USA."
      ]
    }
