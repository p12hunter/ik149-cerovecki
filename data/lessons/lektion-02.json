  "grammar": [
    {
      "title": {
        "de": "Possessivartikel: mein, dein, Ihr",
        "es": "Articulos posesivos: mein, dein, Ihr",
        "en": "Possessive articles: mein, dein, Ihr",
        "ar": "ضمائر الملكية: mein, dein, Ihr",
        "uk": "Присвiйнi артиклi: mein, dein, Ihr",
        "tr": "Iyelik artikelleri: mein, dein, Ihr",
        "bs": "Prisvojni clanovi: mein, dein, Ihr"
      },
      "explanation": {
        "de": "Mein/dein/Ihr werden mit maskulinen und neutralen Nomen verwendet. Bei femininen Nomen und Plural fugen wir ein -e hinzu: meine/deine/Ihre.",
        "es": "Mein/dein/Ihr se usan con sustantivos masculinos y neutros. Con femeninos y plural anadimos -e: meine/deine/Ihre.",
        "en": "Mein/dein/Ihr are used with masculine and neuter nouns. With feminine nouns and plural add -e: meine/deine/Ihre.",
        "ar": "تستخدم mein/dein/Ihr مع أسماء مذكرة ومحايدة. مع المؤنث والجمع نضيف -e: meine/deine/Ihre.",
        "uk": "Mein/dein/Ihr вживаються з чоловiчими i середнiми iменниками. З жiночими i множиною додаємо -e.",
        "tr": "Mein/dein/Ihr eril ve cinssiz isimlerle kullanilir. Disil ve cogulda -e ekleriz.",
        "bs": "Mein/dein/Ihr koriste se sa muskim i srednjim imenicama. Sa zenskim i mnozinom dodajemo -e."
      },
