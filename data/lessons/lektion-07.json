  "grammar": [
    {
      "title": {
        "de": "Modalverben: konnen / wollen",
        "es": "Verbos modales: konnen / wollen",
        "en": "Modal verbs: konnen / wollen",
        "ar": "الأفعال المساعدة: konnen / wollen",
        "uk": "Модальнi дiєслова: konnen / wollen",
        "tr": "Yardimci fiiller: konnen / wollen"
      },
      "explanation": {
        "de": "konnen = Moglichkeit/Fahigkeit (poder, saber). wollen = Absicht/Wille (querer). Beide unregelmassig.",
        "es": "konnen = posibilidad/habilidad (poder, saber hacer). wollen = intencion/voluntad (querer). Ambos irregulares.",
        "en": "konnen = ability/possibility (can). wollen = intention (to want). Both irregular.",
        "ar": "konnen = القدرة. wollen = الإرادة. كلاهما شاذ.",
        "uk": "konnen = можу. wollen = хочу. Обидва неправильнi.",
        "tr": "konnen = -ebilirim. wollen = istiyorum. Her ikisi de duzensiz."
      },
      "table": {
        "headers": ["Pronomen", "konnen", "wollen"],
        "rows": [
          ["ich", "kann", "will"],
          ["du", "kannst", "willst"],
          ["er/sie/es", "kann", "will"],
          ["wir", "konnen", "wollen"],
          ["ihr", "konnt", "wollt"],
          ["sie/Sie", "konnen", "wollen"]
        ]
      }
    },
    {
      "title": {
        "de": "Satzklammer (Modalverb + Infinitiv)",
        "es": "Marco verbal (modal + infinitivo)",
        "en": "Sentence bracket (modal + infinitive)",
        "ar": "الإطار الجملي",
        "uk": "Рамкова конструкцiя",
        "tr": "Cumle cercevesi"
      },
      "explanation": {
        "de": "Das Modalverb steht auf Position 2, der Infinitiv steht am SATZENDE. Sie bilden eine Klammer um den Rest des Satzes.",
        "es": "El verbo modal va en posicion 2, el infinitivo va al FINAL de la oracion. Forman un MARCO alrededor del resto.",
        "en": "Modal verb in position 2, infinitive at the END of the sentence. They form a BRACKET around the rest.",
        "ar": "الفعل المساعد في الموضع 2، المصدر في آخر الجملة.",
        "uk": "Модальне дiєслово на 2-й позицiї, iнфiнiтив у КIНЦI речення.",
        "tr": "Yardimci fiil 2. konumda, mastar cumlenin SONUNDA."
      },
      "examples": [
        "Ich kann nicht in die Schule gehen.",
        "Sie will den Mathetest schreiben.",
        "Kannst du Lili wecken?",
        "Konnen Sie bitte Kaffee kaufen?"
      ]
    },
    {
      "title": {
        "de": "Perfekt - die Vergangenheit",
        "es": "Pretérito perfecto - el pasado",
        "en": "Perfect tense - the past",
        "ar": "الماضي",
        "uk": "Перфект - минулий час",
        "tr": "Gecmis zaman"
      },
      "explanation": {
        "de": "Das Perfekt bilden wir mit haben oder sein + Partizip II. haben fur die meisten Verben. sein fur Bewegung (gehen, fahren, kommen) und Zustandsanderung. Verb-Partizip steht am Ende!",
        "es": "El perfecto se forma con haben o sein + participio II. haben para la mayoria. sein para movimiento (gehen, fahren, kommen) y cambio de estado. El participio va al FINAL!",
        "en": "Perfect tense uses haben or sein + past participle. haben for most verbs. sein for movement (gehen, fahren, kommen) and state change. Participle goes at the END!",
        "ar": "الماضي = haben أو sein + اسم المفعول. haben لمعظم الأفعال. sein للحركة. اسم المفعول في الآخر!",
        "uk": "Перфект = haben або sein + Partizip II. haben для бiльшостi. sein для руху. Дiєприкметник у кiнцi!",
        "tr": "Gecmis zaman = haben veya sein + gecmis ortac. haben cogu icin. sein hareket fiilleri icin. Ortac sonda!"
      },
      "table": {
        "headers": ["Infinitiv", "Hilfsverb", "Partizip II"],
        "rows": [
          ["machen", "haben", "gemacht"],
          ["lernen", "haben", "gelernt"],
          ["essen", "haben", "gegessen"],
          ["gehen", "sein", "gegangen"],
          ["fahren", "sein", "gefahren"],
          ["kommen", "sein", "gekommen"]
        ]
      },
      "examples": [
        "Ich habe Deutsch gelernt.",
        "Lara hat Tee gemacht.",
        "Ich bin nach Berlin gefahren.",
        "Bist du punktlich gekommen?"
      ]
    }
  ],

