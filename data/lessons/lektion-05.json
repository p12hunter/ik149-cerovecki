  "grammar": [
    {
      "title": {
        "de": "Trennbare Verben",
        "es": "Verbos separables",
        "en": "Separable verbs",
        "ar": "الأفعال القابلة للفصل",
        "uk": "Вiдокремлюванi дiєслова",
        "tr": "Ayrilabilir fiiller"
      },
      "explanation": {
        "de": "Trennbare Verben haben ein Prafix (auf-, an-, ein-, fern-, mit-). Das Prafix steht im Satz am Ende! aufstehen -> Ich stehe um 7 Uhr auf.",
        "es": "Los verbos separables tienen un prefijo (auf-, an-, ein-, fern-, mit-). En la oracion el prefijo va al FINAL! aufstehen -> Ich stehe um 7 Uhr auf.",
        "en": "Separable verbs have a prefix (auf-, an-, ein-, fern-, mit-). The prefix goes at the END of the sentence! aufstehen -> Ich stehe um 7 Uhr auf.",
        "ar": "الأفعال القابلة للفصل لها سابقة. السابقة تذهب لآخر الجملة!",
        "uk": "Вiдокремлюванi дiєслова мають префiкс. Префiкс йде в кiнець речення!",
        "tr": "Ayrilabilir fiillerin oneki vardir. Onek cumlenin SONUNA gider!"
      },
      "table": {
        "headers": ["Infinitiv", "ich-Form", "Beispielsatz"],
        "rows": [
          ["aufstehen", "stehe...auf", "Ich stehe um 7 auf."],
          ["anfangen", "fange...an", "Der Kurs fangt um 9 an."],
          ["einkaufen", "kaufe...ein", "Sie kauft im Markt ein."],
          ["fernsehen", "sehe...fern", "Wir sehen am Abend fern."],
          ["anrufen", "rufe...an", "Ich rufe meine Mutter an."]
        ]
      }
    },
    {
      "title": {
        "de": "Prapositionen am, um, von... bis",
        "es": "Preposiciones am, um, von... bis",
        "en": "Prepositions am, um, von... bis",
        "ar": "حروف الجر am, um, von... bis",
        "uk": "Прийменники am, um, von... bis",
        "tr": "am, um, von... bis edatlari"
      },
      "explanation": {
        "de": "am + Tageszeit/Wochentag: am Morgen, am Montag. um + Uhrzeit: um 8 Uhr. von... bis...: zeitlicher Bereich. Ausnahme: in der Nacht.",
        "es": "am + parte del dia / dia de la semana: am Morgen, am Montag. um + hora: um 8 Uhr. von...bis...: rango temporal. Excepcion: in der Nacht.",
        "en": "am + time of day / weekday: am Morgen, am Montag. um + clock time: um 8 Uhr. von...bis...: time range. Exception: in der Nacht.",
        "ar": "am + وقت/يوم. um + ساعة. von...bis...: نطاق زمني. استثناء: in der Nacht.",
        "uk": "am + час доби / день. um + година. von...bis...: часовий дiапазон. Виняток: in der Nacht.",
        "tr": "am + gunun bolumu / gun. um + saat. von...bis...: zaman araligi. Istisna: in der Nacht."
      },
      "examples": [
        "Am Montag arbeite ich.",
        "Der Kurs fangt um 18 Uhr an.",
        "Ich arbeite von 9 bis 17 Uhr.",
        "In der Nacht schlafe ich."
      ]
    },
    {
      "title": {
        "de": "Uhrzeit",
        "es": "La hora",
        "en": "Telling time",
        "ar": "الوقت",
        "uk": "Час",
        "tr": "Saat"
      },
      "explanation": {
        "de": "Im informellen Deutsch sagen wir: Viertel nach (15 Min danach), halb (30 vor der naechsten Stunde!), Viertel vor (15 Min davor).",
        "es": "En aleman informal: Viertel nach (y cuarto), halb (y media - cuidado: indica la mitad de la PROXIMA hora!), Viertel vor (menos cuarto).",
        "en": "In informal German: Viertel nach (quarter past), halb (half - careful: refers to half of the NEXT hour!), Viertel vor (quarter to).",
        "ar": "في الألمانية: Viertel nach (وربع)، halb (ونصف - يشير إلى نصف الساعة التالية!)، Viertel vor (إلا ربع).",
        "uk": "Неформально: Viertel nach (чверть пiсля), halb (пiв - увага: до НАСТУПНОЇ години!), Viertel vor (за чверть).",
        "tr": "Resmi olmayan Almanca: Viertel nach (ceyrek gece), halb (yarim - dikkat: SONRAKI saatin yarimi!), Viertel vor (ceyrek var)."
      },
      "examples": [
        "Es ist 7:15 -> Es ist Viertel nach sieben.",
        "Es ist 7:30 -> Es ist halb acht (achtung: halb 8!)",
        "Es ist 7:45 -> Es ist Viertel vor acht.",
        "Es ist 8:00 -> Es ist acht Uhr."
      ]
    }
  ],

