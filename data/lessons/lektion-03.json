    {
      "title": {
        "de": "Verb mochte- (Hoflichkeit)",
        "es": "Verbo mochte- (cortesia)",
        "en": "Verb mochte- (politeness)",
        "ar": "الفعل mochte- (المجاملة)",
        "uk": "Дiєслово mochte- (ввiчливiсть)",
        "tr": "Mochte- fiili (kibarlik)"
      },
      "explanation": {
        "de": "mochte- ist die hofliche Form von wollen. Wir benutzen es im Geschaft und Restaurant.",
        "es": "mochte- es la forma cortes de wollen (querer). Se usa en tiendas y restaurantes.",
        "en": "mochte- is the polite form of wollen (to want). We use it in shops and restaurants.",
        "ar": "mochte- هي الصيغة المهذبة من wollen. نستخدمها في المتاجر والمطاعم.",
        "uk": "mochte- - ввiчлива форма wollen. Вживаємо в магазинах i ресторанах.",
        "tr": "mochte-, wollen'in kibar halidir. Magaza ve restoranda kullaniriz."
      },
      "table": {
        "headers": ["Pronomen", "mochte-"],
        "rows": [
          ["ich", "mochte"],
          ["du", "mochtest"],
          ["er/sie/es", "mochte"],
          ["wir", "mochten"],
          ["ihr", "mochtet"],
          ["sie/Sie", "mochten"]
        ]
      },
      "examples": [
        "Ich mochte ein Brot, bitte.",
        "Was mochten Sie?",
        "Mochtest du einen Kaffee?"
      ]
    }
