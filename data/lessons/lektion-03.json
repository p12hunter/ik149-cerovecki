  "grammar": [
    {
      "title": {
        "de": "Indefiniter Artikel: ein / eine",
        "es": "Articulo indefinido: ein / eine",
        "en": "Indefinite article: ein / eine",
        "ar": "أداة التنكير: ein / eine",
        "uk": "Неозначений артикль: ein / eine",
        "tr": "Belirsiz artikel: ein / eine",
        "bs": "Neodredeni clan: ein / eine"
      },
      "explanation": {
        "de": "Der unbestimmte Artikel: ein fur maskulin und neutral, eine fur feminin. Im Plural gibt es keinen Artikel.",
        "es": "Articulo indefinido (un/una): ein para masculino y neutro, eine para femenino. En plural NO hay articulo.",
        "en": "Indefinite article (a/an): ein for masculine and neuter, eine for feminine. No article in plural.",
        "ar": "أداة التنكير: ein للمذكر والمحايد، eine للمؤنث. لا توجد أداة في الجمع.",
        "uk": "Неозначений артикль: ein - чоловiчий i середнiй рiд, eine - жiночий. У множинi артикля немає.",
        "tr": "Belirsiz artikel: ein eril ve cinssiz icin, eine disil icin. Cogulda artikel yok.",
        "bs": "Neodredeni clan: ein za muski i srednji rod, eine za zenski. U mnozini nema clana."
      },
