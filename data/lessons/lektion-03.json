  "grammar": [
    {
      "title": {
        "de": "Indefiniter Artikel: ein / eine",
        "es": "Articulo indefinido: ein / eine",
        "en": "Indefinite article: ein / eine",
        "ar": "أداة التنكير: ein / eine",
        "uk": "Неозначений артикль: ein / eine",
        "tr": "Belirsiz artikel: ein / eine"
      },
      "explanation": {
        "de": "Der unbestimmte Artikel: ein fur maskulin und neutral, eine fur feminin. Im Plural gibt es keinen Artikel.",
        "es": "Articulo indefinido (un/una): ein para masculino y neutro, eine para femenino. En plural NO hay articulo.",
        "en": "Indefinite article (a/an): ein for masculine and neuter, eine for feminine. No article in plural.",
        "ar": "أداة التنكير: ein للمذكر والمحايد، eine للمؤنث. لا توجد أداة في الجمع.",
        "uk": "Неозначений артикль: ein - чоловiчий i середнiй рiд, eine - жiночий. У множинi артикля немає.",
        "tr": "Belirsiz artikel: ein eril ve cinssiz icin, eine disil icin. Cogulda artikel yok."
      },
      "table": {
        "headers": ["Genus", "indefinit", "negativ"],
        "rows": [
          ["der (m)", "ein Apfel", "kein Apfel"],
          ["das (n)", "ein Brot", "kein Brot"],
          ["die (f)", "eine Tomate", "keine Tomate"],
          ["Plural", "- Tomaten", "keine Tomaten"]
        ]
      },
      "examples": [
        "Ich mochte einen Apfel.",
        "Das ist ein Ei.",
        "Wir haben keine Milch."
      ]
    },
    {
      "title": {
        "de": "Plural - der Plural ist wichtig!",
        "es": "Plural - el plural es importante!",
        "en": "Plural - the plural is important!",
        "ar": "الجمع - الجمع مهم!",
        "uk": "Множина - множина важлива!",
        "tr": "Cogul - cogul onemlidir!"
      },
      "explanation": {
        "de": "Im Deutschen gibt es verschiedene Pluralformen. Bitte den Plural immer mit dem Wort lernen!",
        "es": "En aleman hay varias formas de plural. Aprende SIEMPRE el plural junto a la palabra!",
        "en": "German has several plural forms. Always learn the plural together with the word!",
        "ar": "في الألمانية أشكال جمع مختلفة. تعلم الجمع دائما مع الكلمة!",
        "uk": "У нiмецькiй кiлька форм множини. Завжди вчи множину разом зi словом!",
        "tr": "Almancada farkli cogul ekleri vardir. Cogulu her zaman kelimeyle birlikte ogrenin!"
